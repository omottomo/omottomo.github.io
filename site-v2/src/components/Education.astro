---
import Section from './Section.astro';
import { education } from '../data/certifications';
---

<Section id="education" title="학력">
  <div class="border-t border-rule-strong">
    {
      education.map((edu) => (
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 border-b border-rule py-6">
          <div>
            <h3 class="font-display text-xl font-bold tracking-tight text-ink">
              {edu.school}
            </h3>
            <p class="mt-1 font-mono text-sm text-muted">
              {[edu.major, edu.degree].filter(Boolean).join(' · ')}
            </p>
          </div>
          {edu.period && (
            <span class="font-mono text-sm tabular-nums text-muted">
              {edu.period}
            </span>
          )}
        </div>
      ))
    }
  </div>
</Section>
