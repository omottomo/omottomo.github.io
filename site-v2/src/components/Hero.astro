---
import { site } from '../data/site';
import { experiences } from '../data/experience';

// Contact CTA — 정적 사이트(백엔드 없음)라 mailto로 방문자의 메일 클라이언트를 바로 연다.
const mailtoHref = `mailto:${site.email}?subject=${encodeURIComponent('포트폴리오 문의')}`;

// CURRENTLY 블록 — 현재 재직 정보는 experience 데이터를 단일 진실원본으로 사용.
const current = experiences.find((e) => e.active) ?? experiences[0];
const currentPeriod = current.period;
---

<section class="scroll-mt-16">
  <span id="top" class="sr-only"></span>

  <div class="mx-auto max-w-6xl px-5 pb-16 pt-14 sm:px-8 sm:pb-24 sm:pt-24">
    <div class="grid grid-cols-1 gap-x-10 gap-y-12 lg:grid-cols-[2fr_1fr]">
      <!-- 좌: 인트로 — 태그라인 · 이름 · 리드 · CTA (버튼은 등폭 그리드로 가로 일렬) -->
      <div>
        <p class="font-display text-2xl leading-snug text-faint sm:text-[1.75rem]">
          DevOps Engineer
        </p>

        <h1
          class="mt-2 font-display text-[clamp(2.6rem,7vw,4.5rem)] font-extrabold leading-[1.02] tracking-tight text-ink"
        >
          이동욱
        </h1>
        <p class="mt-4 font-mono text-sm tracking-wide text-muted">1997.05.06</p>
        <p class="mt-8 max-w-xl text-base leading-relaxed text-ink-soft sm:text-lg">
          안정적인 시스템 운영은 <strong class="font-semibold text-ink">단순함</strong>에서
          비롯된다 생각합니다.</br> 
          해당 목표를 이루기 위해 노력하는 <strong class="font-semibold text-ink">DevOps Engineer</strong> 입니다.
        </p>



        <div class="mt-10 grid max-w-md grid-cols-1 gap-2.5 sm:grid-cols-3">
          <!-- Projects 섹션이 채워지기 전까지 PROJECT 버튼 대신 경력으로 유도 -->
          <a
            href="#experience"
            class="inline-flex items-center justify-center gap-2 border border-ink px-4 py-2.5 font-mono text-xs font-medium uppercase tracking-wide text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            </svg>
            EXPERIENCE
          </a>
          <a
            href={site.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 border border-ink px-4 py-2.5 font-mono text-xs font-medium uppercase tracking-wide text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            GITHUB
          </a>
          <a
            href={mailtoHref}
            class="inline-flex items-center justify-center gap-2 border border-ink px-4 py-2.5 font-mono text-xs font-medium uppercase tracking-wide text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            CONTACT
          </a>
        </div>
      </div>

      <!-- 우: CURRENTLY(재직) — 헤어라인 컬럼 구분 · 세로 가운데 정렬 -->
      <div class="flex flex-col justify-center lg:border-l lg:border-rule lg:pl-10">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-muted">
          Currently
        </p>
        <img
          src="/images/thundersoft-logo.png"
          alt="ThunderSoft 로고"
          class="theme-logo mt-4 h-5 w-auto self-start"
          width="1492"
          height="187"
          loading="eager"
        />
        <p class="mt-2.5 font-display text-xl font-semibold text-ink">{current.company}</p>
        <p class="mt-1.5 font-mono text-xs tracking-wide text-faint">{currentPeriod}</p>
      </div>
    </div>
  </div>
</section>
