---
import Section from './Section.astro';
import { projects } from '../data/projects';
// 기술 칩 앞 기호 — Skills 카테고리 아이콘을 공유해 두 섹션의 분류 체계를 일치시킨다
import { icons, techIcon } from '../data/icons';

// Problem → Approach → Result 3단 원장 — [라벨, 데이터 필드] 쌍으로 순회
const par = [
  ['Problem', 'problem'],
  ['Approach', 'approach'],
  ['Result', 'result'],
] as const;
---

<Section
  id="projects"
  title="Projects"
>
  {/* 프로젝트 원장 — 카드 대신 헤어라인 괘선으로 구분되는 전폭 스택 (LEDGER//GRID) */}
  <div class="divide-y divide-rule">
    {
      projects.map((p, idx) => (
        <article class="py-12 first:pt-0 last:pb-0">
          <span class="font-mono text-xs tracking-widest text-faint">
            PRJ.{String(idx + 1).padStart(2, '0')}
          </span>

          <h3 class="mt-2 font-display text-2xl font-bold leading-snug tracking-tight text-ink sm:text-[1.7rem]">
            {p.title}
          </h3>

          {/* 메타 — 기간 · 역할 · 기여도 (스크린샷의 서브타이틀 라인) */}
          <p class="mt-2.5 flex flex-wrap items-center gap-x-2.5 gap-y-1 font-mono text-[0.8rem] tabular-nums text-muted">
            {p.meta.map((m, i) => (
              <>
                {i > 0 && (
                  <span aria-hidden="true" class="text-faint">
                    ·
                  </span>
                )}
                <span>{m}</span>
              </>
            ))}
          </p>

          {/* Problem / Approach / Result — 버밀리언 틱 사각 + 모노 라벨 */}
          <div class="mt-8 space-y-6">
            {par.map(([label, key]) => (
              <div>
                <h4 class="flex items-center gap-2.5 font-mono text-xs font-semibold uppercase tracking-[0.22em] text-ink">
                  <span aria-hidden="true" class="h-2 w-2 flex-none bg-accent" />
                  {label}
                </h4>
                <p class="mt-2.5 max-w-5xl pl-[1.125rem] leading-relaxed text-ink-soft break-keep">
                  {p[key]}
                </p>
              </div>
            ))}
          </div>

          {/* 기술 칩 — radius 0 · 헤어라인 보더 (사이트 정체성 유지) */}
          <ul class="mt-7 flex flex-wrap gap-2" aria-label="사용 기술">
            {p.tech.map((t) => (
              <li class="inline-flex items-center gap-1.5 border border-rule-strong bg-panel px-2.5 py-1 font-mono text-xs text-ink-soft">
                {techIcon[t] && (
                  <svg
                    class="h-3 w-3 shrink-0 text-muted"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={icons[techIcon[t]]}
                  />
                )}
                {t}
              </li>
            ))}
          </ul>

          {p.links && p.links.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-4">
              {p.links.map((l) => (
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-accent font-mono text-sm"
                >
                  {l.label} →
                </a>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </div>
</Section>
