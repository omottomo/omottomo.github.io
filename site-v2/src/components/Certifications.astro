---
import Section from './Section.astro';
import { certifications } from '../data/certifications';
---

<Section
  id="certifications"
  title="Certifications"
  subtitle="공개적으로 검증 가능한 자격을 실제 자산으로 제시합니다."
>
  <div class="border-t border-rule-strong">
    {
      certifications.map((cert) => (
        <div class="border-b border-rule py-6">
          <h3 class="font-display text-xl font-bold tracking-tight text-ink">
            {cert.name}
          </h3>
          <p class="mt-1 font-mono text-sm text-muted">
            {cert.issuer} · 취득 {cert.date}
          </p>
        </div>
      ))
    }
  </div>
</Section>
