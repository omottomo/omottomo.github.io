---
import Section from './Section.astro';
import { skillGroups } from '../data/skills';
// 카테고리 아이콘 — Projects 기술 칩과 공유하는 단일 진실원본 (data/icons.ts)
import { icons } from '../data/icons';
---

<Section
  id="skills"
  title="Skills"
  subtitle="구현을 위해 필요한 기술들을 깊이 있게 다룹니다."
>
  <div class="grid gap-px border border-rule-strong bg-rule-strong sm:grid-cols-2 lg:grid-cols-3">
    {
      skillGroups.map((group) => (
        <div class="bg-paper p-6">
          <div class="flex items-center gap-3">
            <span
              class="inline-flex h-8 w-8 shrink-0 items-center justify-center border border-rule text-ink"
              aria-hidden="true"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={icons[group.icon]}
              />
            </span>
            <h3 class="font-display text-lg font-bold tracking-tight text-ink">
              {group.category}
            </h3>
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span
                title={item.note}
                class:list={[
                  'cursor-default border px-2.5 py-1 font-mono text-xs',
                  item.highlighted
                    ? 'border-ink font-medium text-ink'
                    : 'border-rule text-muted',
                ]}
              >
                {item.name}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>
