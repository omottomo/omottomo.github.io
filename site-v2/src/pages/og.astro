---
// OG 카드 (1200×630) — Ledger 톤. 헤드리스 Chrome으로 이 라우트를 캡처해
// public/og-image.png 를 생성한다. 사이트 본문에는 링크되지 않는 유틸 라우트.
import '../styles/global.css';
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <title>OG — 이동욱</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      html, body { margin: 0; padding: 0; overflow: hidden; background: #f4f2ea; }
    </style>
  </head>
  <body>
    <div
      class="flex h-[630px] w-[1200px] flex-col justify-between bg-paper px-16 py-14"
    >
      <!-- 데이트라인 -->
      <div>
        <div
          class="flex items-center justify-between font-mono text-xl uppercase tracking-[0.2em] text-muted"
        >
          <span class="flex items-center gap-3">
            <span class="inline-block h-4 w-4 bg-accent"></span>Portfolio / 2026
          </span>
          <span>omottomo.github.io</span>
        </div>
        <div class="mt-6 h-px w-full bg-ink"></div>
      </div>

      <!-- 이름 + 역할·성과 -->
      <div>
        <div
          class="font-display text-[128px] font-extrabold leading-none tracking-tight text-ink"
        >
          이동욱
        </div>
        <div
          class="mt-7 font-display text-[46px] font-bold leading-tight tracking-tight text-ink"
        >
          빌드 시간을 <span class="text-build tabular-nums">75%↓</span> 줄이는 DevOps 엔지니어
        </div>
      </div>

      <!-- 정량 성과 원장 -->
      <div>
        <div class="h-px w-full bg-rule-strong"></div>
        <dl class="mt-7 grid grid-cols-3 divide-x divide-rule-strong">
          <div class="pr-10">
            <dt class="font-mono text-lg uppercase tracking-widest text-muted">
              전체 빌드 시간
            </dt>
            <dd class="mt-2 font-display text-[54px] font-bold leading-none tabular-nums text-ink">
              12h→3h
            </dd>
            <dd class="mt-3 font-mono text-xl text-build-ink">▼ 75% 단축</dd>
          </div>
          <div class="px-10">
            <dt class="font-mono text-lg uppercase tracking-widest text-muted">
              TDD 테스트 사이클
            </dt>
            <dd class="mt-2 font-display text-[54px] font-bold leading-none tabular-nums text-ink">
              102→73<span class="ml-2 font-mono text-2xl text-muted">min</span>
            </dd>
            <dd class="mt-3 font-mono text-xl text-build-ink">▼ 28% 단축</dd>
          </div>
          <div class="pl-10">
            <dt class="font-mono text-lg uppercase tracking-widest text-muted">
              AWS Solutions Architect
            </dt>
            <dd class="mt-2 font-display text-[54px] font-bold leading-none text-ink">
              SAA
            </dd>
            <dd class="mt-3 font-mono text-xl text-ink-soft">
              Associate <span class="text-build-ink">· 검증가능</span>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </body>
</html>
